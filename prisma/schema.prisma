generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  groups UsersUserGroups[]

  @@map("users")
}

model UserGroup {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users  UsersUserGroups[]
  scopes UserGroupsUserScopes[]

  @@map("user_groups")
}

model UserScope {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  groups UserGroupsUserScopes[]

  @@map("user_scopes")
}

model UsersUserGroups {
  userId    String    @map("user_id") @db.Uuid
  groupId   String    @map("group_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("users_user_groups")
}

model UserGroupsUserScopes {
  groupId   String    @map("group_id") @db.Uuid
  scopeId   String    @map("scope_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scope UserScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@id([groupId, scopeId])
  @@map("user_groups_user_scopes")
}

model Color {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  imagePath   String?  @map("image_path")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  collections CollectionColors[]

  @@map("colors")
}

model Collection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  colors   CollectionColors[]
  products ProductCollections[]

  @@map("collections")
}

model CollectionColors {
  collectionId String @map("collection_id") @db.Uuid
  colorId      String @map("color_id") @db.Uuid

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  color      Color      @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([collectionId, colorId])
  @@map("collection_colors")
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  priceCents  Int      @default(0) @map("price_cents")
  imagePath   String?  @map("image_path")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  collections ProductCollections[]
  variants    ProductVariant[]

  @@map("products")
}

model ProductCollections {
  productId    String @map("product_id") @db.Uuid
  collectionId String @map("collection_id") @db.Uuid

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

model ProductVariant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  title     String   @db.VarChar(255)
  sku       String?  @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Order {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerEmail String   @map("customer_email") @db.VarChar(255)
  totalQuantity Int      @map("total_quantity")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(10, 2)
  paid          Boolean  @default(false)
  status        String   @default("initial") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy     String?  @map("created_by") @db.VarChar(255)

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId       String   @map("product_id") @db.VarChar(255)
  productTitle    String   @map("product_title") @db.VarChar(500)
  productImageUrl String?  @map("product_image_url") @db.VarChar(1000)
  variantId       String   @map("variant_id") @db.VarChar(255)
  variantTitle    String   @map("variant_title") @db.VarChar(500)
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
